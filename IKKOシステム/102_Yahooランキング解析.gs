function Yahoo売買代金ランキングを解析する_(html) {
  const text = HTMLをプレーンテキスト化する_(html)
    .replace(/\s+/g, ' ')
    .trim();

  const 開始候補一覧 = [
    '順位 名称・コード・市場 取引値 前日比 売買代金',
    '順位名称・コード・市場取引値前日比売買代金'
  ];

  let 本文開始位置 = -1;
  let 開始文字 = '';

  for (let i = 0; i < 開始候補一覧.length; i++) {
    const 候補 = 開始候補一覧[i];
    const 位置 = text.indexOf(候補);
    if (位置 >= 0) {
      本文開始位置 = 位置;
      開始文字 = 候補;
      break;
    }
  }

  if (本文開始位置 < 0) return [];

  let 本文 = text.substring(本文開始位置 + 開始文字.length).trim();

  const 終了候補一覧 = [
    '情報提供会社のリンクは、すべて外部サイトへ移動します。',
    'Yahoo!ファイナンス Yahoo! JAPAN',
    'プライバシーポリシー',
    '免責事項（必ずお読みください）'
  ];

  for (let i = 0; i < 終了候補一覧.length; i++) {
    const 候補 = 終了候補一覧[i];
    const 位置 = 本文.indexOf(候補);
    if (位置 >= 0) {
      本文 = 本文.substring(0, 位置).trim();
      break;
    }
  }

  const 結果 = [];
  const 追加済み = {};

  const 市場パターン = '(東証PRM|東証STD|東証GRT|東証ETF|東証REIT|名証[^ ]*|札証|福証)';

  // 1) スペースあり版
  const 正規表現_スペースあり = new RegExp(
    '(?:^|\\s)' +
    '(\\d{1,2})\\s+' +                     // 順位
    '(.+?)\\s+' +                          // 銘柄名
    '([0-9A-Z]{4,5})\\s+' +                // 銘柄コード
    市場パターン + '\\s+' +               // 市場
    '掲示板\\s+' +
    '([0-9][0-9,\\.]*)\\s+' +              // 株価
    '(\\d{2}\\/\\d{2})\\s+' +              // 日付
    '([+\\-][0-9,\\.]+)\\s+' +             // 前日比値
    '([+\\-][0-9\\.]+)\\s*%\\s+' +         // 前日比率
    '([0-9]{1,3}(?:,[0-9]{3})+)' +         // 売買代金
    '(?=\\s+\\d{1,2}\\s+|$)',              // 次順位 or 末尾
    'g'
  );

  let 一致;
  while ((一致 = 正規表現_スペースあり.exec(本文)) !== null) {
    const 順位 = Number(一致[1]);
    if (!(順位 >= 1 && 順位 <= 50)) continue;

    const 銘柄コード = 一致[3];
    const キー = 順位 + '_' + 銘柄コード;
    if (追加済み[キー]) continue;
    追加済み[キー] = true;

    結果.push({
      順位: 順位,
      銘柄名: 一致[2].trim(),
      銘柄コード: 銘柄コード,
      市場: 一致[4],
      株価: 数値化する_(一致[5]),
      日付: 一致[6],
      前日比値: 一致[7],
      前日比率: 数値化する_(一致[8]),
      売買代金: 数値化する_(一致[9]),
      取得元: 'yahoo'
    });
  }

  // 2) スペース少なめ/連結版
  const 正規表現_連結版 = new RegExp(
    '(\\d{1,2})' +                         // 順位
    '(.+?)' +                              // 銘柄名
    '([0-9A-Z]{4,5})\\s*' +                // 銘柄コード
    市場パターン + '\\s*' +               // 市場
    '掲示板\\s*' +
    '([0-9][0-9,\\.]*)\\s*' +              // 株価
    '(\\d{2}\\/\\d{2})\\s*' +              // 日付
    '([+\\-][0-9,\\.]+)\\s*' +             // 前日比値
    '([+\\-][0-9\\.]+)\\s*%\\s*' +         // 前日比率
    '([0-9]{1,3}(?:,[0-9]{3})+)' +         // 売買代金
    '(?=\\d{1,2}.+?[0-9A-Z]{4,5}\\s*' + 市場パターン + '\\s*掲示板|$)',
    'g'
  );

  while ((一致 = 正規表現_連結版.exec(本文)) !== null) {
    const 順位 = Number(一致[1]);
    if (!(順位 >= 1 && 順位 <= 50)) continue;

    const 銘柄コード = 一致[3];
    const キー = 順位 + '_' + 銘柄コード;
    if (追加済み[キー]) continue;
    追加済み[キー] = true;

    結果.push({
      順位: 順位,
      銘柄名: 一致[2].trim(),
      銘柄コード: 銘柄コード,
      市場: 一致[4],
      株価: 数値化する_(一致[5]),
      日付: 一致[6],
      前日比値: 一致[7],
      前日比率: 数値化する_(一致[8]),
      売買代金: 数値化する_(一致[9]),
      取得元: 'yahoo'
    });
  }

  結果.sort(function(a, b) {
    return a.順位 - b.順位;
  });

  return 結果;
}

function Yahoo更新日時を解析する_(html) {
  const text = HTMLをプレーンテキスト化する_(html)
    .replace(/\s+/g, ' ')
    .trim();

  const 一致 = text.match(/更新日時[：:]\s*(\d{4}\/\d{2}\/\d{2}\s+\d{2}:\d{2})/);

  if (!一致) {
    return '';
  }

  return 一致[1];
}